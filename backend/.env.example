# 平台模式
MODE=demo

# LLM provider: mock | groq | gemini | ollama | openrouter
LLM_PROVIDER=mock
# 留白=用 provider 預設 model
LLM_MODEL=
# 企業網路 self-signed CA 時設為 false（GroqProvider 已優先試 OS truststore）
LLM_SSL_VERIFY=true

# API keys
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# 資料路徑
SQLITE_PATH=./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
# 相對 backend 啟動 cwd；workspaces 在 repo 根目錄所以是 ../workspaces
WORKSPACES_DIR=../workspaces

# 行為旗標
SEED_ON_BOOT=true
LOG_LEVEL=INFO

# CORS（前端網域）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

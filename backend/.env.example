# 平台模式
MODE=demo

# LLM provider: mock | groq | gemini | ollama | openrouter
LLM_PROVIDER=mock
# 留白=用 provider 預設 model
LLM_MODEL=
# 企業網路 self-signed CA 時設為 false（GroqProvider 已優先試 OS truststore）
LLM_SSL_VERIFY=true

# API keys
GROQ_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434

# 資料路徑
SQLITE_PATH=./data/app.db
CHROMA_PERSIST_DIR=./data/chroma
# 相對 backend 啟動 cwd；workspaces 在 repo 根目錄所以是 ../workspaces
WORKSPACES_DIR=../workspaces

# 行為旗標
SEED_ON_BOOT=true
LOG_LEVEL=INFO

# CORS（前端網域）
ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# ── Phase 6 — Tool Synthesis ─────────────────────────────────
# E2B sandbox key（PROD 用；空字串 → fallback 到 LocalSubprocessRunner）
# 取得方式：https://e2b.dev/dashboard/keys
E2B_API_KEY=

# Telegram HITL（PLAN §22.4.4 / §22.5.7）
# Bot token 從 BotFather (@BotFather on Telegram) 申請；空字串 = 整套 HITL 停用
TG_BOT_TOKEN=
# 你的 chat_id（先傳一個訊息給 bot，呼叫 getUpdates 看 chat.id）
TG_CHAT_ID=
# polling = 無公網 URL 也能用（dev）；webhook = PROD（需 HTTPS URL）
TG_MODE=polling

# Generated tools 寫到哪（相對 backend 啟動 cwd）
GENERATED_TOOLS_DIR=../workspaces/generated_tools

# Chat 觸發合成時，read_only 工具是否自動 approve（demo 友善 vs prod 嚴謹）
CHAT_AUTO_APPROVE_READ_ONLY=true
